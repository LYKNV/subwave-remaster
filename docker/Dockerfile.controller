FROM node:22-bookworm-slim

# Piper TTS dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates wget tar \
    && rm -rf /var/lib/apt/lists/*

# Install Piper (CPU-only, fine for short DJ segments)
ARG PIPER_VERSION=2023.11.14-2
RUN cd /tmp && \
    wget -q https://github.com/rhasspy/piper/releases/download/${PIPER_VERSION}/piper_linux_x86_64.tar.gz && \
    tar -xzf piper_linux_x86_64.tar.gz -C /opt && \
    ln -s /opt/piper/piper /usr/local/bin/piper && \
    rm piper_linux_x86_64.tar.gz

# British English voice — lift the same one you use in Kaze
RUN mkdir -p /opt/piper/voices && \
    wget -q -O /opt/piper/voices/en_GB-alan-medium.onnx \
      https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_GB/alan/medium/en_GB-alan-medium.onnx && \
    wget -q -O /opt/piper/voices/en_GB-alan-medium.onnx.json \
      https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_GB/alan/medium/en_GB-alan-medium.onnx.json

# Controller app
WORKDIR /app
COPY controller/package*.json ./
RUN npm install --omit=dev
COPY controller/src ./src

# State dir shared with Liquidsoap
RUN mkdir -p /var/sub-wave/voice && chmod 777 /var/sub-wave

EXPOSE 7701
CMD ["node", "src/server.js"]
